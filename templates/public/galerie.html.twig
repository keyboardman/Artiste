{% extends 'base.html.twig' %}

{% block title %}Placeaupro - Galerie{% endblock %}

{% block body_class %}galerie-page{% endblock %}

{% block nav_transparent %}true{% endblock %}

{% block content %}
    <section class="categories">
        {% set default_categories = ['Illustration', 'Photographie', 'Graphisme', 'Peinture', 'Digital Painting', 'Motion Design'] %}

        <button class="category active" data-category="all">Tous</button>

        {% for category in categories|default(default_categories) %}
            <button class="category"
                    data-category="{{ category|lower|replace({' ': '-'}) }}">
                {{ category }}
            </button>
        {% endfor %}
    </section>

    <section class="galerie">
        <div class="masonry">
            {% for article in articles %}
                <div class="item" data-category="{{ article.category|lower|replace({' ': '-'}) }}">
                    <img src="{{ asset(article.image) }}" alt="{{ article.title }}" />
                </div>
            {% else %}
                <p class="galerie-empty">Aucune œuvre disponible pour le moment.</p>
            {% endfor %}
        </div>
    </section>
{% endblock %}
