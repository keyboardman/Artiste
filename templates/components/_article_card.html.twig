{#
    Composant Article Card

    Variables:
    - article: objet article avec id, image, title, description, price
    - show_link: boolean pour afficher le lien vers la page détail
#}

<a href="{{ path('app_article_show', {id: article.id}) }}" class="article-card">
    <img src="{{ asset(article.image) }}" alt="{{ article.title }}">
    <h4>{{ article.title|upper }}</h4>
    <p>{{ article.description }}</p>
    <span class="article-card-btn">AJOUTER AU PANIER</span>
</a>
